komodo.perpixai.ir {
    reverse_proxy komodo-core:9120
}

cdn-dashboard.perpixai.ir {
	reverse_proxy http://rustfs:9001
}

cdn.perpixai.ir {
	reverse_proxy http://rustfs:9000
}


cdn.perpixai.com {
		reverse_proxy http://rustfs:9000
}


api.perpixai.ir {
	reverse_proxy http://perpix-api:8000
}

app.perpixai.ir {
	@sw_file {
		path /sw.js
	}
	header @sw_file Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

	@html_file {
		path / /index.html
	}
	header @html_file Cache-Control "no-cache, must-revalidate"

	reverse_proxy http://perpix-app:8080
}


perpixai.ir {
	reverse_proxy http://perpix-main-landing:8080
}

